{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "categories", "legacyCategoryAliases"],
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "integer", "minimum": 1 },
    "categories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "description", "subcategories"],
        "properties": {
          "id": { "$ref": "#/$defs/identifier" },
          "label": { "type": "string", "minLength": 2, "maxLength": 80 },
          "description": { "type": "string", "minLength": 20, "maxLength": 240 },
          "subcategories": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "label"],
              "properties": {
                "id": { "$ref": "#/$defs/identifier" },
                "label": { "type": "string", "minLength": 2, "maxLength": 80 }
              }
            }
          }
        }
      }
    },
    "legacyCategoryAliases": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/identifier" }
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    }
  }
}
